{
  "name": "youtube-hover-actions",
  "version": "1.1.2",
  "private": true,
  "type": "module",
  "description": "Chrome extension that exposes YouTube card menu actions on hover.",
  "scripts": {
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "build": "node scripts/build.js --none",
    "pack": "node scripts/build.js --all",
    "pack:chrome": "node scripts/build.js --chrome",
    "pack:firefox": "node scripts/build.js --firefox",
    "test": "node --import tsx --test test/**/*.test.ts",
    "lint": "eslint src/**/*.ts test/**/*.ts",
    "format": "prettier --write src/**/*.ts test/**/*.ts",
    "format:check": "prettier --check src/**/*.ts test/**/*.ts",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test"
  },
  "devDependencies": {
    "@eslint/js": "^9.5.0",
    "@types/chrome": "^0.2.0",
    "@types/node": "^20.14.9",
    "eslint": "^9.5.0",
    "globals": "^15.6.0",
    "prettier": "^3.3.2",
    "tsup": "^8.1.0",
    "tsx": "^4.15.7",
    "typescript": "^5.5.2",
    "typescript-eslint": "^8.0.0-alpha.34"
  }
}
